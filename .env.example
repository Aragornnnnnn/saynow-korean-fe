# 백엔드 API 서버 주소 (Next.js rewrites /api/* → 이 주소로 프록시)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# 백엔드 없이 목업(MSW)으로 로컬 확인 (dev에서만 동작)
NEXT_PUBLIC_MSW=false

# 쉼표로 구분한 Next.js 개발 서버 허용 origin
NEXT_ALLOWED_DEV_ORIGINS=

# 로컬 개발용 임시 로그인
NEXT_PUBLIC_ENABLE_DEV_LOGIN=false
NEXT_PUBLIC_DEV_ACCESS_TOKEN=
NEXT_PUBLIC_DEV_REFRESH_TOKEN=

# Deepgram STT (서버 전용 — NEXT_PUBLIC_ 붙이지 말 것)
DEEPGRAM_API_KEY=

# Amplitude Analytics
NEXT_PUBLIC_AMPLITUDE_API_KEY=

# 웹 브라우저 소셜 로그인
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
NEXT_PUBLIC_KAKAO_REST_API_KEY=
NEXT_PUBLIC_KAKAO_JS_KEY=
KAKAO_CLIENT_SECRET=
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback
